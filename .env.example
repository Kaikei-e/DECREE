# Environment variables for decree services.
# Sensitive values are managed via Docker Secrets (see secrets/ directory).
# Copy this file to .env and fill in any non-secret overrides.

# NVD API key is loaded from secrets/nvd_api_key.txt
# Webhook URLs are loaded from secrets/slack_webhook_url.txt, secrets/discord_webhook_url.txt
# Webhook token is loaded from secrets/decree_webhook_token.txt
# Postgres password is loaded from secrets/postgres_password.txt
